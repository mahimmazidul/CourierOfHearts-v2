# Backend
HOST=127.0.0.1
PORT=3847
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=365d
LETTER_MASTER_KEY=replace-with-a-long-random-master-key
DB_FILE=server/data/letters.db
LEGACY_DATA_FILE=server/data/letters.json
CACHE_DIR=server/cache
CORS_ORIGIN=http://localhost:5173
ADMIN_API_ENABLED=false
ADMIN_MASTER_KEY=replace-with-a-long-random-admin-key
MYSQL_MIRROR_URL=
MAX_FLOWERS=50
BODY_LIMIT_BYTES=131072
DAILY_CACHE_TTL_MS=86400000

# Frontend (development)
VITE_API_BASE_URL=http://127.0.0.1:3847/api/v1
VITE_SINGLEFILE=false
VITE_ENABLE_ADMIN_PANEL=false
VITE_ADMIN_ROUTE=sudo

# Frontend tuneables
VITE_LETTER_BODY_FONT_SIZE=17
VITE_LETTER_BODY_FONT_SIZE_MD=18
VITE_LETTER_LINE_HEIGHT=1.95
VITE_FLOWER_OPACITY_COMPOSE=0.62
VITE_FLOWER_OPACITY_PREVIEW=0.30
VITE_FLOWER_OPACITY_READING=0.28
VITE_MAX_FLOWERS=50
VITE_TYPEWRITER_MIN_MS=28
VITE_TYPEWRITER_MAX_MS=50
VITE_TYPEWRITER_BOOST_AFTER_MS=1000
VITE_TYPEWRITER_BOOST_FACTOR=0.82
VITE_DRAFT_TTL_MS=86400000
VITE_DRAFT_SAVE_INTERVAL_MS=2000
